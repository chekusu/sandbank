{
  "name": "@sandbank.dev/agent",
  "version": "0.1.0",
  "description": "Lightweight client for AI agents running inside Sandbank sandboxes",
  "license": "MIT",
  "type": "module",
  "homepage": "https://sandbank.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/agent"
  },
  "keywords": ["sandbox", "ai-agent", "client", "cli"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sandbank-agent": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@sandbank.dev/core": "workspace:*"
  },
  "devDependencies": {
    "@sandbank.dev/core": "workspace:*",
    "@sandbank.dev/relay": "workspace:*",
    "@types/node": "^22.15.0",
    "typescript": "^5.7.3",
    "ws": "^8.18.0",
    "@types/ws": "^8.18.0"
  }
}
