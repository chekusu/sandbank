{
  "name": "@sandbank/core",
  "version": "0.1.0",
  "description": "Unified sandbox SDK for AI agents — provider abstraction, capability system, and error types",
  "license": "MIT",
  "type": "module",
  "homepage": "https://sandbank.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/core"
  },
  "keywords": ["sandbox", "ai-agent", "cloud", "provider", "sdk"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@sandbank/relay": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@sandbank/relay": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sandbank/relay": "workspace:*",
    "@types/node": "^22.15.0",
    "typescript": "^5.7.3",
    "ws": "^8.18.0",
    "@types/ws": "^8.18.0"
  }
}
