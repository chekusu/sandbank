{
  "name": "sandbank-cloudflare-e2e",
  "main": "worker.ts",
  "compatibility_date": "2025-01-13",
  "compatibility_flags": ["nodejs_compat"],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "max_instances": 5,
      "instance_type": "lite"
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "SANDBOX", "class_name": "Sandbox" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Sandbox"] }]
}
