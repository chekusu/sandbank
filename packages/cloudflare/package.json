{
  "name": "@sandbank/cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare Workers sandbox adapter for Sandbank",
  "license": "MIT",
  "type": "module",
  "homepage": "https://sandbank.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/cloudflare"
  },
  "keywords": ["sandbox", "ai-agent", "cloudflare", "workers", "cloud"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.7.0",
    "@sandbank/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  }
}
