{
  "name": "sandbank",
  "version": "0.5.4",
  "description": "Workspace Agent Harness and sandbox orchestration CLI for AI agents",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/sandbank"
  },
  "homepage": "https://sandbank.dev",
  "keywords": [
    "sandbox",
    "workspace",
    "harness",
    "ai-agent",
    "ai",
    "agent",
    "cloud",
    "sdk",
    "cli",
    "daytona",
    "flyio",
    "cloudflare",
    "multi-agent",
    "orchestration"
  ],
  "bin": {
    "sandbank": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./harness-api": {
      "types": "./dist/harness-api.d.ts",
      "import": "./dist/harness-api.js"
    },
    "./harness-worker": {
      "types": "./dist/harness-worker.d.ts",
      "import": "./dist/harness-worker.js"
    },
    "./harness-node": {
      "types": "./dist/harness-node.d.ts",
      "import": "./dist/harness-node.js"
    },
    "./harness-benchmark": {
      "types": "./dist/harness-benchmark.d.ts",
      "import": "./dist/harness-benchmark.js"
    },
    "./agent-supervisor": {
      "types": "./dist/agent-supervisor.d.ts",
      "import": "./dist/agent-supervisor.js"
    },
    "./tool-use": {
      "types": "./dist/tool-use.d.ts",
      "import": "./dist/tool-use.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "harness-benchmark.cases.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "bench:harness": "tsx src/cli/index.ts harness-benchmark --cases ./harness-benchmark.cases.json"
  },
  "dependencies": {
    "@sandbank.dev/cloud": "workspace:*",
    "@sandbank.dev/cloudflare": "workspace:*",
    "@sandbank.dev/core": "workspace:*",
    "@sandbank.dev/db9": "workspace:*",
    "@sandbank.dev/workspace": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3"
  }
}
