{
  "name": "sandbank",
  "version": "0.1.0",
  "description": "Unified sandbox SDK for AI agents — write once, run on any cloud",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/sandbank"
  },
  "homepage": "https://sandbank.dev",
  "keywords": [
    "sandbox",
    "ai-agent",
    "ai",
    "agent",
    "cloud",
    "sdk",
