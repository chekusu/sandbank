{
  "name": "sandbank",
  "version": "0.5.1",
  "description": "Unified sandbox SDK and CLI for AI agents — write once, run on any cloud",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chekusu/sandbank.git",
    "directory": "packages/sandbank"
  },
  "homepage": "https://sandbank.dev",
  "keywords": [
    "sandbox",
    "ai-agent",
    "ai",
    "agent",
    "cloud",
    "sdk",
    "cli",
    "daytona",
    "flyio",
    "cloudflare",
    "multi-agent",
    "orchestration"
  ],
  "bin": {
    "sandbank": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sandbank.dev/cloud": "workspace:*",
    "@sandbank.dev/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3"
  }
}
